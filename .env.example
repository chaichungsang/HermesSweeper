# Required: Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-ant-api03-...

# Required: GitHub token for gh CLI (or set via gh auth login)
GITHUB_TOKEN=ghp_...

# Required: Target repository to sweep (owner/repo format)
TARGET_REPO=owner/repo

# Optional: Repository where sweep reports are stored
# REPORT_REPO=owner/sweeper-repo

# Optional: Override Claude model
# MODEL=claude-sonnet-4-20250514

# Optional: Override max tokens
# MAX_TOKENS=4096

# Optional: Fresh review window in days
# FRESH_DAYS=7
